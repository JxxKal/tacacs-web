# Copy to .env and fill in. Do not commit .env.

# --- Logging / timezone ---
LOG_LEVEL=INFO
TZ=Europe/Berlin

# --- Postgres ---
POSTGRES_DB=tacacs
POSTGRES_USER=tacacs
# POSTGRES_PASSWORD lives in ../secrets/postgres_password (one line, no trailing newline).

# --- Base URL (used for SAML ACS callbacks, absolute links, etc.) ---
BASE_URL=https://tacacs.internal.example.com:8443

# --- TACACS+ shared secret accepted from every NAS (M2 catch-all host block).
#     M4 narrows this to per-Device secrets stored encrypted in the DB. ---
TACACS_SHARED_SECRET=changeme-before-production

# --- Bind addresses (default: all interfaces). Restrict to one IP if you don't want
#     TACACS exposed to your full host network. ---
TACACS_BIND_ADDR=0.0.0.0
HTTP_BIND_ADDR=0.0.0.0
HTTPS_BIND_ADDR=0.0.0.0
