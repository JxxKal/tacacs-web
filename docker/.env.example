# Copy to .env and fill in (plain `docker compose`), or paste these as
# "Environment variables" when creating the Portainer stack. Do not commit .env.

# --- Logging / timezone ---
LOG_LEVEL=INFO
TZ=Europe/Berlin

# --- Postgres ---
POSTGRES_DB=tacacs
POSTGRES_USER=tacacs
# DB password — used by both the `db` and `backend` services. REQUIRED.
POSTGRES_PASSWORD=change-me-strong-db-password

# --- AES-GCM master key — base64 of 32 bytes. REQUIRED. ---
#   Generate with:  openssl rand -base64 32
#   This key decrypts every stored device secret — treat it like a root
#   credential. As an env var it is visible via `docker inspect`; for a
#   file mount instead, see DEPLOY.md §3.8.
MASTER_KEY=replace-with-output-of-openssl-rand-base64-32

# --- Base URL (used for SAML ACS callbacks, absolute links, etc.) ---
BASE_URL=https://tacacs.internal.example.com:8443

# --- TACACS+ shared secret accepted from every NAS (M2 catch-all host block).
#     M4 narrows this to per-Device secrets stored encrypted in the DB. ---
TACACS_SHARED_SECRET=changeme-before-production

# --- Bind addresses (default: all interfaces). Restrict to one IP if you don't want
#     TACACS / the UI exposed on every host interface. ---
TACACS_BIND_ADDR=0.0.0.0
HTTPS_BIND_ADDR=0.0.0.0

# --- Host port for the HTTPS listener. Override when 8443 is already in use
#     on the host. The container still listens on 8443 internally; this only
#     affects the host-side mapping. ---
HTTPS_HOST_PORT=8443
